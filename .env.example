# Database
DATABASE_URL=postgresql://docsextract:docsextract@localhost:5432/docex
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200
ES_INDEX_NAME=documents

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=documents.ingest
KAFKA_GROUP_ID=documents-ingest-consumer

# Rate limiting
RATE_LIMIT_SEARCH=100
RATE_LIMIT_INDEX=50
RATE_LIMIT_GLOBAL=500
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_REDIS_TTL=2

# Cache
CACHE_TTL_DOC=300
CACHE_TTL_SEARCH=60
CACHE_SCAN_COUNT=100

# Connection pool
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_QUERY_TIMEOUT=5
MAX_CONTENT_LENGTH=1048576

# Search defaults
SEARCH_DEFAULT_PAGE=1
SEARCH_DEFAULT_SIZE=20
SEARCH_MAX_SIZE=100

# Application
DEBUG=false
REDIS_DECODE_RESPONSES=true
VERSION=0.1.0

# Deployment (Oracle Free Tier / Docker Compose)
PG_PASSWORD=docsextract       # PostgreSQL password (override for production)
DOMAIN=                       # Public domain for Caddy HTTPS (e.g. docex.example.com)
EMAIL=                        # Let's Encrypt email for certificate notifications
CADDY_HTTP_PORT=80            # Caddy HTTP host port (change if port 80 is taken)
CADDY_HTTPS_PORT=443          # Caddy HTTPS host port (change if port 443 is taken)
