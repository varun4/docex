# Database
DATABASE_URL=postgresql://docsextract:docsextract@localhost:5432/docex
REDIS_URL=redis://localhost:6379/0

# Rate limiting
RATE_LIMIT_SEARCH=100
RATE_LIMIT_INDEX=10
RATE_LIMIT_GLOBAL=1000
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_REDIS_TTL=2

# Cache
CACHE_TTL_DOC=300
CACHE_TTL_SEARCH=60
CACHE_SCAN_COUNT=100

# Connection pool
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_QUERY_TIMEOUT=5
MAX_CONTENT_LENGTH=1048576

# Search defaults
SEARCH_DEFAULT_PAGE=1
SEARCH_DEFAULT_SIZE=20
SEARCH_MAX_SIZE=100

# Full-text search
FTS_LANGUAGE=english
FTS_RANK_NORMALIZATION=1

# Application
DEBUG=false
REDIS_DECODE_RESPONSES=true
VERSION=0.1.0
